# ── UŻYTKOWNICY (login:hasło, oddzielone przecinkami) ──────
USERS=maciej:haslo123,anna:haslo456

# ── MONGODB ────────────────────────────────────────────────
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/

# ── WEBHOOKI N8N (globalne fallbacki) ─────────────────────
WEBHOOK_A=https://xxx.n8n.cloud/webhook/agent-a
WEBHOOK_B=https://xxx.n8n.cloud/webhook/agent-b

# ── WEBHOOKI PER-USER (opcjonalne, nadpisują globalne) ─────
# Format: WEBHOOK_{MODEL}_{USER_UPPERCASE}
WEBHOOK_A_MACIEJ=https://xxx.n8n.cloud/webhook/maciej-agent-a
WEBHOOK_B_MACIEJ=https://xxx.n8n.cloud/webhook/maciej-agent-b

# ── FEEDBACK (opcjonalne — dokąd wysłać raporty błędów) ───
FEEDBACK_WEBHOOK_A=
FEEDBACK_WEBHOOK_B=

# ── PORT ───────────────────────────────────────────────────
PORT=5000
